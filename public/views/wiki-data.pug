doctype html
html(lang="en")
  include includes/head.pug
  body
    header
      include includes/navbar.pug
    main.container
      h1 #{title} Wiki.
      section.text #{heading}
      a.back-link(href=(typeof listPath !== 'undefined' ? listPath : '/wiki')) Back to Wiki

    searchbar.container
    form.search-wrapper(action="/" + title.toLowerCase() method="GET" id="searchForm") Search by name: 
      input(type="text" name="item" placeholder="I'm looking for..." aria-label="Search for something specific" id="searchInput")
      button(type="submit") Search
      p#searchMessage Not found

    dropdown.container
      if title === 'Plants'
        label(for='plant-family') OR Search by family:
        select#plant-family(name='plant-family')
          option(value='') -- Select a family --
        label(for='plant-select' style='margin-left:1rem') Plant:
        select#plant-select(name='plant-select' disabled)
          option(value='') -- Select a plant --

    body.container
    section.text List of #{title}:
      if data && data.length > 0
        ol
          each item in data
            - var name = (item && (item.name || item.title || item.id)) || item || ''
            if name
              li
                a(href=("?item=" + encodeURIComponent(name))) #{name}
            else
              li No name
      else
        p No data available
    include includes/footer.pug

  script.
    const data = !{JSON.stringify(data)};
    const plantFamilies = !{JSON.stringify(typeof plantFamilies !== 'undefined' ? plantFamilies : null)};
    const searchForm = document.getElementById('searchForm');
    const searchInput = document.getElementById('searchInput');
    const searchMessage = document.getElementById('searchMessage');

    searchForm.addEventListener('input', (e) => {
      if (searchInput.value.length > 0) {
        searchMessage.style.display = 'none';
      }
    });

    searchForm.addEventListener('submit', (e) => {
      const searchTerm = searchInput.value.trim().toLowerCase();
      const itemExists = data.some(item => {
        const name = (item && (item.name || item.title || item.id)) || item || '';
        return name.toString().toLowerCase() === searchTerm;
      });

      if (!itemExists) {
        e.preventDefault();
        searchMessage.style.display = 'block';
      } else {
        searchMessage.style.display = 'none';
      }
    });

    // Family / plant dropdowns (Plants page only)
    const familySelect = document.getElementById('plant-family');
    const plantSelect = document.getElementById('plant-select');

    if (familySelect && plantSelect && plantFamilies) {
      // Populate family dropdown from server-provided map
      Object.keys(plantFamilies).forEach(family => {
        const opt = document.createElement('option');
        opt.value = family;
        opt.textContent = family;
        familySelect.appendChild(opt);
      });

      familySelect.addEventListener('change', () => {
        const chosen = familySelect.value;
        plantSelect.innerHTML = '<option value="">-- Select a plant --</option>';
        if (!chosen) {
          plantSelect.disabled = true;
          return;
        }
        (plantFamilies[chosen] || []).forEach(name => {
          const opt = document.createElement('option');
          opt.value = name;
          opt.textContent = name;
          plantSelect.appendChild(opt);
        });
        plantSelect.disabled = false;
      });

      plantSelect.addEventListener('change', () => {
        const chosen = plantSelect.value;
        if (chosen) {
          window.location.href = '?item=' + encodeURIComponent(chosen.toLowerCase());
        }
      });
    }