doctype html
html(lang="en")
  include includes/head.pug
  body
    header
      include includes/navbar.pug
    main.container
      h1 #{title} Wiki.      
      section.text  #{heading}
      a.back-link(href=(typeof listPath !== 'undefined' ? listPath : '/wiki')) Back to Wiki
      if detailData
        .detail
          a.back-link(href=(typeof listPath !== 'undefined' ? listPath : '/')) Back to list
          if detailData && typeof detailData === 'object' && !Array.isArray(detailData)
            ul
              each val, key in detailData
                li
                  strong #{key}: 
                  |  #{val}
          else if Array.isArray(detailData)
            ul
              each val in detailData
                li #{val}
          else
            p #{detailData}
      else if data && data.length > 0
        ol
          each item in data
            - var name = (item && (item.name || item.title || item.id)) || item || ''
            if name
              li
                a(href=("?item=" + encodeURIComponent(name))) #{name}
            else
              li No name
      else
        p No data available
    include includes/footer.pug