//- Details page for a single wiki item
doctype html
html(lang="en")
  include includes/head.pug
  body
    header
      include includes/navbar.pug
    main.container
      h1 #{title} Details
      section.text #{heading}
      a.back-link(href=(typeof listPath !== 'undefined' ? listPath : '/')) Back to list
      if detailData
        .detail
          if detailData && typeof detailData === 'object' && !Array.isArray(detailData)
            ul
              each val, key in detailData
                li
                  strong #{key}: 
                  |  #{val}
          else if Array.isArray(detailData)
            ul
              each val in detailData
                li #{val}
          else
            p #{detailData}
      else
        p No data available
    include includes/footer.pug
